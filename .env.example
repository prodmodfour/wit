# Copy this file to .env for local overrides. Never commit the resulting .env.

# All persistent host data lives below this one root. The fixed subpaths are:
#   config/      service configuration
#   cache/       service runtime caches
#   downloads/   download-client data shared with Sonarr
#   television/  the organised television library
WIT_DATA_ROOT=./data

# Generic container identity and time-zone defaults. Adjust PUID and PGID locally
# when the containers need to match a different host user.
PUID=1000
PGID=1000
TZ=Etc/UTC

# Host-side ports. Compose binds administrative ports to localhost by default.
QBITTORRENT_PORT=8080
SONARR_PORT=8989
JELLYFIN_PORT=8096
SEERR_PORT=5055
